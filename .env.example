# Nutrient Web SDK license key. Get one from https://my.nutrient.io/.
# Required for production builds; inlined into the viewer bundle at build time by Vite.
#
# The `verify-license-env.mjs` build guard fails the build if this var is unset
# or still matches the <YOUR_LICENSE_KEY_HERE> placeholder. To deliberately build
# a trial-mode artefact (viewer will watermark every page), set it to an empty
# string: `VITE_NUTRIENT_LICENSE_KEY=`.
VITE_NUTRIENT_LICENSE_KEY=<YOUR_LICENSE_KEY_HERE>
